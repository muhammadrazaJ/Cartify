@{
    ViewData["Title"] = "Admin Dashboard";
    var userId = ViewBag.UserId as string ?? "N/A";
    var email = ViewBag.Email as string ?? "N/A";
    var role = ViewBag.Role as string ?? "N/A";
}

<div class="text-center py-5">
    <h1 class="display-4">Admin Dashboard</h1>
    <p class="lead text-muted">This page is protected. Only users with Admin role can access.</p>
    <p><strong>Role from JWT:</strong> @role</p>
    <p><strong>User ID:</strong> @userId</p>
    <p><strong>Email:</strong> @email</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary mt-3">Go to Home</a>
</div>
