@model Cartify.Models.CustomerDetailDto
@{
    var activate = ViewBag.Activate as bool? ?? true;
    ViewData["Title"] = activate ? "Activate Customer" : "Deactivate Customer";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">@(activate ? "Activate" : "Deactivate") Customer</h1>
    <a asp-controller="Admin" asp-action="Details" asp-route-id="@Model?.UserId" class="btn btn-outline-secondary">Cancel</a>
</div>

@if (Model != null)
{
    <div class="card border-@(activate ? "success" : "warning") shadow-sm">
        <div class="card-body">
            <p class="lead mb-3">
                @if (activate)
                {
                    <text>Are you sure you want to <strong>activate</strong> this customer account?</text>
                }
                else
                {
                    <text>Are you sure you want to <strong>deactivate</strong> this customer account?</text>
                }
            </p>
            <p class="text-muted mb-4">
                <strong>@Model.FullName</strong> (@Model.Email) — User ID: @Model.UserId
            </p>

            <form method="post" asp-controller="Admin" asp-action="@(activate ? "Activate" : "Deactivate")" asp-route-id="@Model.UserId" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn @(activate ? "btn-success" : "btn-warning")">
                    @(activate ? "Yes, Activate" : "Yes, Deactivate")
                </button>
            </form>
            <a asp-controller="Admin" asp-action="Details" asp-route-id="@Model.UserId" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
}
else
{
    <p class="text-muted">Customer not found.</p>
}
